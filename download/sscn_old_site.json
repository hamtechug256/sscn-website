    "html": "<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SSCN | Nursing &amp; Midwifery School in Soroti, Uganda</title>\n    <meta name=\"description\" content=\"Start your nursing or midwifery career at SSCN in Soroti, Uganda. We offer diploma programs with modern labs, expert faculty, and high graduate success. Apply today!\">\n    <meta name=\"google-site-verification\" content=\"QR1HBf3n-p82L2s8USU-kpiWPTDgnhcuwAyfjbOwXe8\">\n    \n    <!-- Preconnect to Google Fonts for performance -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n    \n    <!-- Google Fonts: Poppins (Headings) & Inter (Body) -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Poppins:wght@600;700;800&amp;display=swap\" rel=\"stylesheet\">\n    \n    <!-- Main Stylesheet -->\n    <link rel=\"stylesheet\" href=\"css/style.css\">\n    <link rel=\"stylesheet\" href=\"css/testimonials.css\">\n\n    <!-- Font Awesome for Icons -->\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n\n    <!-- OneSignal for Push Notifications -->\n    <script src=\"https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js\" defer=\"\"></script>\n    <script>\n      window.OneSignalDeferred = window.OneSignalDeferred || [];\n      OneSignalDeferred.push(async function(OneSignal) {\n        await OneSignal.init({\n          appId: \"ff8e7f90-2047-4033-952c-c34d8b121b09\",\n        });\n        promptOneSignal(); // Call the prompt function here\n      });\n    </script>\n    <script type=\"application/ld+json\">\n    {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"EducationalOrganization\",\n      \"name\": \"Soroti School of Comprehensive Nursing\",\n      \"url\": \"https://www.sorotinursing.ac.ug\",\n      \"logo\": \"https://www.sorotinursing.ac.ug/images/logo.png\",\n      \"contactPoint\": {\n        \"@type\": \"ContactPoint\",\n        \"telephone\": \"+256-7XX-XXX-XXX\",\n        \"contactType\": \"Admissions\",\n        \"email\": \"info@sorotinursing.ac.ug\"\n      },\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"addressLocality\": \"Soroti City\",\n        \"addressRegion\": \"Eastern Region\",\n        \"addressCountry\": \"UG\"\n      },\n      \"sameAs\": [\n        \"https://www.facebook.com/sorotinursing\",\n        \"https://twitter.com/sorotinursing\"\n      ]\n    }\n    </script>\n<script src=\"https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.es6.js?v=160601\" defer=\"\"></script></head>\n<body style=\"\">\n    <!-- Preloader -->\n    <div id=\"preloader\">\n        <div class=\"loader\"></div>\n    </div>\n\n    <!--================================================\n      HEADER & NAVIGATION\n    ================================================-->\n    <header class=\"main-header\">\n        <div class=\"container\">\n            <nav class=\"main-nav\">\n                <a class=\"logo\" href=\"/\">SSCN<span>.</span></a>\n                <ul class=\"nav-links\">\n                    <li class=\"nav-link active\"><a href=\"/\">Home</a></li>\n                    <li class=\"nav-link\"><a href=\"/about\">About Us</a></li>\n                    <li class=\"nav-link\"><a href=\"/programs\">Programs</a></li>\n                    <li class=\"nav-link\"><a href=\"/admissions\">Admissions</a></li>\n                    \n                    <li class=\"nav-link\"><a href=\"/news\">News</a></li>\n                    <li class=\"nav-link\"><a href=\"/gallery\">Gallery</a></li>\n                    <li class=\"nav-link\"><a href=\"/campus-map\">Campus Map</a></li>\n                    <li class=\"nav-link\"><a href=\"#contact\">Contact</a></li>\n                </ul>\n                <button class=\"menu-toggle\" aria-label=\"Open Menu\">☰</button>\n            </nav>\n        </div>\n    </header>\n\n    <main>\n\n        <!--================================================\n          HERO SECTION\n        ================================================-->\n        <section class=\"hero\">\n            \n            <div class=\"container\">\n                <div class=\"hero-content\">\n                    <h1><span class=\"highlight-text\">Soroti School of Comprehensive Nursing</span></h1>\n                    <p>Empowering the next generation of healthcare professionals in Uganda with world-class, compassionate, and innovative training.</p>\n                    <div class=\"hero-buttons\">\n                        <a href=\"#about\" class=\"btn btn-primary\">Learn More</a>\n                        <a class=\"btn btn-secondary\" href=\"/programs\">Our Programs</a>\n                    </div>\n                    <div class=\"hero-features\">\n                        <div class=\"feature\">\n                            <i class=\"fas fa-flask\"></i>\n                            <span>Modern Labs</span>\n                        </div>\n                        <div class=\"feature\">\n                            <i class=\"fas fa-user-tie\"></i>\n                            <span>Expert Faculty</span>\n                        </div>\n                        <div class=\"feature\">\n                            <i class=\"fas fa-graduation-cap\"></i>\n                            <span>High Graduate Success</span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"hero-image\">\n                    <img src=\"images/nurse-hero.png\" alt=\"Professional Nurse\" loading=\"lazy\">\n                </div>\n            </div>\n        </section>\n\n        <!--================================================\n          ABOUT SECTION\n        ================================================-->\n        <section id=\"about\" class=\"section about-section\">\n            <div class=\"container\">\n                <div class=\"section-title\">\n                    <h2>About Soroti School of Comprehensive Nursing</h2>\n                </div>\n                <div class=\"about-panel\">\n                    <div class=\"about-image scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <img src=\"images/nursing_students.webp\" alt=\"A diverse group of nursing students in a modern classroom setting\" loading=\"lazy\">\n                    </div>\n                    <div class=\"about-text scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <p>Soroti School of Comprehensive Nursing is a leading institution dedicated to training competent and compassionate healthcare professionals. Located in Soroti City, Uganda, we are committed to providing high-quality education in nursing and midwifery.</p>\n                        <p>Our programs are designed to equip students with the knowledge, skills, and ethical values necessary to excel in the dynamic healthcare sector. We foster a learning environment that encourages critical thinking, practical expertise, and a commitment to community health.</p>\n                        <a class=\"btn btn-primary\" href=\"/about\">Read More About Us</a>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!--================================================\n          PROGRAMS SECTION\n        ================================================-->\n        <section id=\"programs\" class=\"section programs-section bg-light-alt\">\n            <div class=\"container\">\n                <div class=\"section-title\">\n                    <h2>Our Academic Programs</h2>\n                </div>\n                <div class=\"programs-grid\">\n                    <!-- Program Card 1 -->\n                    <div class=\"program-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"program-card-icon\"></div>\n                        <h3>Diploma in Nursing</h3>\n                        <p>A comprehensive program blending rigorous theory with practical clinical experience for a rewarding healthcare career.</p>\n                        <a class=\"card-link\" href=\"/programs\">Learn More →</a>\n                    </div>\n                    <!-- Program Card 2 -->\n                    <div class=\"program-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"program-card-icon\"></div>\n                        <h3>Diploma in Midwifery</h3>\n                        <p>Specialized training in maternal and child health, empowering students to become skilled and compassionate midwives.</p>\n                        <a class=\"card-link\" href=\"/programs\">Learn More →</a>\n                    </div>\n                    <!-- Program Card 3 -->\n                    <div class=\"program-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"program-card-icon\"></div>\n                        <h3>Diploma in Nursing (Extension)</h3>\n                        <p>An extension program for practicing nurses to upgrade their qualifications and enhance their clinical expertise.</p>\n                        <a class=\"card-link\" href=\"/programs\">Learn More →</a>\n                    </div>\n                    <!-- Program Card 4 -->\n                    <div class=\"program-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"program-card-icon\"></div>\n                        <h3>Diploma in Midwifery (Extension)</h3>\n                        <p>Upgrade your midwifery qualifications with our extension program focused on advanced practices and leadership.</p>\n                        <a class=\"card-link\" href=\"/programs\">Learn More →</a>\n                    </div>\n                    <!-- Program Card 5 -->\n                    <div class=\"program-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"program-card-icon\"></div>\n                        <h3>Diploma in Nursing (E-Learning)</h3>\n                        <p>Flexible online learning for the theoretical components of our Diploma in Nursing, ideal for working professionals.</p>\n                        <a class=\"card-link\" href=\"/programs\">Learn More →</a>\n                    </div>\n                    <!-- Program Card 6 -->\n                    <div class=\"program-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"program-card-icon\"></div>\n                        <h3>Diploma in Midwifery (E-Learning)</h3>\n                        <p>A flexible online program delivering our expert midwifery curriculum for students seeking remote learning options.</p>\n                        <a class=\"card-link\" href=\"/programs\">Learn More →</a>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!--================================================\n          WHY CHOOSE US SECTION\n        ================================================-->\n        <section id=\"why-choose-us\" class=\"section why-choose-us-section\">\n            <div class=\"container\">\n                <div class=\"section-title\">\n                    <h2>Why Choose SSCN?</h2>\n                </div>\n                <div class=\"reasons-grid\">\n                    <div class=\"reason-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"reason-icon\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 14l9-5-9-5-9 5 9 5z\"></path><path d=\"M12 14l6.16-3.422 A12.044 12.044 0 0 1 22 12v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-6c0-2.28.788-4.388 2.16-6.08\"></path></svg>\n                        </div>\n                        <h3>Experienced Faculty</h3>\n                        <p>Learn from highly qualified and experienced educators who are experts in their fields and dedicated to your success.</p>\n                    </div>\n                    <div class=\"reason-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"reason-icon\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"></path><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"></path></svg>\n                        </div>\n                        <h3>Modern Facilities</h3>\n                        <p>Access state-of-the-art classrooms, laboratories, and clinical simulation centers designed for immersive learning.</p>\n                    </div>\n                    <div class=\"reason-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"reason-icon\">\n                            <i class=\"fas fa-stethoscope\"></i>\n                        </div>\n                        <h3>Clinical Exposure</h3>\n                        <p>Gain invaluable hands-on experience through extensive clinical placements in leading healthcare facilities.</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!--================================================\n          TESTIMONIALS SECTION\n        ================================================-->\n        <section id=\"testimonials\" class=\"section testimonials-section\">\n            <div class=\"container\">\n                <div class=\"section-title\">\n                    <h2>What Our Students Say</h2>\n                </div>\n                <div id=\"testimonials-container\" class=\"testimonials-grid\"><div class=\"testimonial-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <img src=\"images/students/grace.jpg\" alt=\"Abenoja Grace\">\n                        <blockquote>\"The hands-on clinical experience I gained at SSCN was invaluable. The instructors are knowledgeable and supportive, and they truly care about their students' success.\"</blockquote>\n                        <cite>- Abenoja Grace</cite>\n                    </div><div class=\"testimonial-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <img src=\"images/students/susan.jpg\" alt=\"Apio Susan\">\n                        <blockquote>\"I am so grateful for the education I received at SSCN. The school prepared me for a successful career in midwifery, and I am now able to make a real difference in my community.\"</blockquote>\n                        <cite>- Apio Susan</cite>\n                    </div><div class=\"testimonial-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <img src=\"images/students/david.jpg\" alt=\"Nabuyobo Arafat\">\n                        <blockquote>\"The e-learning program at SSCN was a perfect fit for my busy schedule. I was able to continue working while I earned my diploma, and the online platform was easy to use and engaging.\"</blockquote>\n                        <cite>- Nabuyobo Arafat</cite>\n                    </div><div class=\"testimonial-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"testimonial-content\">\n                            <blockquote>The hands-on clinical experience I gained at SSCN was invaluable. The instructors are knowledgeable and supportive, and they truly care about their students' success.</blockquote>\n                            <div class=\"author-info\">\n                                <img src=\"images/students/grace.jpg\" alt=\"Photo of Abenoja Grace\">\n                                <div class=\"author-details\">\n                                    <p class=\"name\">Abenoja Grace</p>\n                                    <p class=\"program\">Diploma in Nursing</p>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"testimonial-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"testimonial-content\">\n                            <blockquote>I am so grateful for the education I received at SSCN. The school prepared me for a successful career in midwifery, and I am now able to make a real difference in my community.</blockquote>\n                            <div class=\"author-info\">\n                                <img src=\"images/students/susan.jpg\" alt=\"Photo of Apio Susan\">\n                                <div class=\"author-details\">\n                                    <p class=\"name\">Apio Susan</p>\n                                    <p class=\"program\">Diploma in Midwifery</p>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"testimonial-card scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <div class=\"testimonial-content\">\n                            <blockquote>The e-learning program at SSCN was a perfect fit for my busy schedule. I was able to continue working while I earned my diploma, and the online platform was easy to use and engaging.</blockquote>\n                            <div class=\"author-info\">\n                                <img src=\"images/students/david.jpg\" alt=\"Photo of Nabuyobo Arafat\">\n                                <div class=\"author-details\">\n                                    <p class=\"name\">Nabuyobo Arafat</p>\n                                    <p class=\"program\">Diploma in Nursing (E-Learning)</p>\n                                </div>\n                            </div>\n                        </div>\n                    </div></div>\n            </div>\n        </section>\n\n        <!--================================================\n          CONTACT SECTION\n        ================================================-->\n        <section id=\"contact\" class=\"section contact-section bg-light-alt\">\n            <div class=\"container\">\n                <div class=\"section-title\">\n                    <h2>Get in Touch</h2>\n                </div>\n                <div class=\"contact-content\">\n                    <div class=\"contact-info scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <h3>Contact Information</h3>\n                        <p>Have questions? We'd love to hear from you. Reach out to us via any of the methods below.</p>\n                        <ul>\n                            <li><strong>Location:</strong> Soroti City, Uganda</li>\n                            <li><strong>Email:</strong> <a href=\"mailto:info@sorotinursing.ac.ug\">info@sorotinursing.ac.ug</a></li>\n                            <li><strong>Phone:</strong> <a href=\"tel:+256700000000\">+256 7XX XXX XXX</a></li>\n                        </ul>\n                    </div>\n                    <div class=\"contact-form scroll-reveal\" style=\"translate: none; rotate: none; scale: none; transform: translate(0px, 50px); opacity: 0;\">\n                        <form name=\"contact\" method=\"POST\" data-netlify=\"true\" class=\"modern-form\">\n                            <div class=\"form-group\">\n                                <label for=\"name\">Your Name</label>\n                                <input type=\"text\" id=\"name\" name=\"name\" placeholder=\"Enter your name\" required=\"\">\n                            </div>\n                            <div class=\"form-group\">\n                                <label for=\"email\">Your Email</label>\n                                <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"Enter your email\" required=\"\">\n                            </div>\n                            <div class=\"form-group\">\n                                <label for=\"subject\">Subject</label>\n                                <input type=\"text\" id=\"subject\" name=\"subject\" placeholder=\"Subject of your message\">\n                            </div>\n                            <div class=\"form-group\">\n                                <label for=\"message\">Your Message</label>\n                                <textarea id=\"message\" name=\"message\" placeholder=\"Type your message here...\" rows=\"6\" required=\"\"></textarea>\n                            </div>\n                            <button type=\"submit\" class=\"btn btn-primary\">Send Message</button>\n                        </form>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n    </main>\n\n    <!--================================================\n      FOOTER\n    ================================================-->\n    <footer class=\"main-footer\">\n        <div class=\"container\">\n            <div class=\"footer-grid\">\n                <div class=\"footer-column about\">\n                    <h4>About SSCN</h4>\n                    <p>The Soroti School of Comprehensive Nursing is dedicated to training the next generation of healthcare leaders in Uganda through excellence in education, research, and clinical practice.</p>\n                </div>\n                <div class=\"footer-column links\">\n                    <h4>Quick Links</h4>\n                    <ul class=\"footer-links\">\n                        <li><a href=\"/about\">About Us</a></li>\n                        <li><a href=\"/programs\">Our Programs</a></li>\n                        <li><a href=\"/admissions\">Admissions</a></li>\n                        <li><a href=\"/news\">News &amp; Events</a></li>\n                    </ul>\n                </div>\n                <div class=\"footer-column links\">\n                    <h4>Student Resources</h4>\n                    <ul class=\"footer-links\">\n                        <li><a href=\"/campus-life\">Campus Life</a></li>\n                        <li><a href=\"#faq\">FAQ</a></li>\n                        <li><a href=\"#contact\">Contact Support</a></li>\n                    </ul>\n                </div>\n                <div class=\"footer-column contact\">\n                    <h4>Contact Us</h4>\n                    <p>Soroti City, Uganda</p>\n                    <p><a href=\"mailto:info@sorotinursing.ac.ug\">info@sorotinursing.ac.ug</a></p>\n                    <p><a href=\"tel:+256700000000\">+256 7XX XXX XXX</a></p>\n                    <div class=\"footer-socials\">\n                        <!-- Add social links here when available -->\n                    </div>\n                </div>\n            </div>\n            <div class=\"footer-bottom\">\n                <p>© 2025 Soroti School of Comprehensive Nursing. All Rights Reserved. | Designed by Hamcodz</p>\n            </div>\n        </div>\n    </footer>\n\n    <!-- Back to Top Button -->\n    <button id=\"scroll-top-btn\" aria-label=\"Scroll to top\">↑</button>\n\n    <!-- News Toast Notification -->\n    <div id=\"news-toast\" class=\"news-toast\"></div>\n\n    <!-- Main Script -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js\"></script>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js\"></script>\n    <script src=\"js/script.js\"></script>\n    <script src=\"js/testimonials.js\"></script>\n\n\n\n</body></html>",
